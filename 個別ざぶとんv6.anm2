--group:ざぶとん3-5,false

--check@bg_enable3:ざぶとん3,0
--track@bg_x3:ざぶとん3サイズx,0,2000,0,1
--track@bg_y3:ざぶとん3サイズy,0,2000,0,1
--color@bg_col3:ざぶとん3色,0x641e64
--track@bg_overall_posx3:ざぶとん3全体x,-100000,100000,0,1
--track@bg_overall_posy3:ざぶとん3全体y,-100000,100000,0,1
--track@bg_posx3:ざぶとん3背景x,-100000,100000,0,1
--track@bg_posy3:ざぶとん3背景y,-100000,100000,0,1
--track@bg_alpha3:ざぶとん3透明度,0,100,100,0.1
--track@bg_text_posx3:ざぶとん3文字x,-100000,100000,0,1
--track@bg_text_posy3:ざぶとん3文字y,-100000,100000,0,1
--track@bg_start3:ざぶとん3開始文字(個別オブジェクト時),0,500,7,1
--track@bg_end3:ざぶとん3終了文字(個別オブジェクト時),0,500,10,1
--track@bg_frame_size3:ざぶとん3枠線サイズ,0,500,0,1
--track@bg_frame_blur3:ざぶとん3枠線ぼかし,0,100,0,1

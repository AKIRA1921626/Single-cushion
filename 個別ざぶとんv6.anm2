--track@bg_y2:ざぶとん2サイズy,0,2000,0,1
--color@bg_col2:ざぶとん2色,0xc81919
--track@bg_overall_posx2:ざぶとん2全体x,-100000,100000,0,1
--track@bg_overall_posy2:ざぶとん2全体y,-100000,100000,0,1
--track@bg_posx2:ざぶとん2背景x,-100000,100000,0,1
--track@bg_posy2:ざぶとん2背景y,-100000,100000,0,1
--track@bg_alpha2:ざぶとん2透明度,0,100,100,0.1
--track@bg_text_posx2:ざぶとん2文字x,-100000,100000,0,1
--track@bg_text_posy2:ざぶとん2文字y,-100000,100000,0,1
--track@bg_start2:ざぶとん2開始文字(個別オブジェクト時),0,500,3,1
--track@bg_end2:ざぶとん2終了文字(個別オブジェクト時),0,500,6,1
